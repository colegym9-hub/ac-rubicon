# AC Rubicon — environment template. Copy to .env.local and fill in.
# .env.local is gitignored; this file is committed as documentation.

# Supabase: PUBLIC
# (anon key is unused under the server-side service-role model; never reference
#  NEXT_PUBLIC_SUPABASE_ANON_KEY inside a `use client` file)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase: SECRET (server only — all DB access uses the service-role key)
SUPABASE_SERVICE_ROLE_KEY=

# App password gate (SECRETS)
#   APP_PASSWORD   — the password to unlock the app
#   SESSION_SECRET — long random string (e.g. `openssl rand -base64 32`)
APP_PASSWORD=
SESSION_SECRET=

# MCP server (SECRET) — bearer token the remote MCP endpoint (/api/mcp) requires.
#   Any Claude client (cloud routine, laptop) sends `Authorization: Bearer <this>`.
#   Generate a long random value, e.g. `openssl rand -base64 32`
MCP_BEARER_TOKEN=

# M2 scheduler (added later, not needed for M0/M1)
ANTHROPIC_API_KEY=
NTFY_TOPIC=
